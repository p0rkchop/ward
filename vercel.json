{
  "crons": [
    {
      "path": "/api/cron/reminders",
      "schedule": "0 13 * * *"
    }
  ],
  "functions": {
    "app/api/**/*": {
      "maxDuration": 10
    }
  },
  "installCommand": "npm install",
  "buildCommand": "npx prisma generate && npx prisma db push && npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "regions": ["iad1"]
}